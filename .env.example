# Copy to `.env.local` for local development (never commit `.env.local`).
# Notion-backed pages (research archive, success stories, team, news) need the API key.

NOTION_API_KEY=

# Database IDs — match your workspace (see scripts/sync-notion.ts for defaults used in tooling).
NOTION_RESEARCH_DB_ID=
NOTION_SUCCESS_STORIES_DB_ID=
NOTION_TEAM_DB_ID=

# Optional — public URLs for linking to Notion read views.
NEXT_PUBLIC_NOTION_SUCCESS_STORIES_SITE=

# Optional — set "1" to load Figma html-to-design capture helper in layout (see layout.tsx).
# NEXT_PUBLIC_FIGMA_HTML_CAPTURE=0
